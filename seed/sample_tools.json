[
  {
    "id": "scheduling.create-meeting",
    "name": "Create Meeting",
    "description": "Schedule a meeting with one or more attendees, with optional recurrence",
    "category": "scheduling",
    "version": "1.0.0",
    "tool_type": "REST_API",
    "endpoint": "https://api.internal.example.com/scheduling/meetings",
    "input_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "attendees": { "type": "array", "items": { "type": "string", "format": "email" }, "minItems": 1 },
        "start_time": { "type": "string", "format": "date-time" },
        "duration_minutes": { "type": "integer", "minimum": 15, "maximum": 480 },
        "recurrence": { "type": "string", "enum": ["none", "daily", "weekly", "monthly"] }
      },
      "required": ["title", "attendees", "start_time", "duration_minutes"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "meeting_id": { "type": "string" },
        "join_url": { "type": "string", "format": "uri" },
        "status": { "type": "string" }
      }
    },
    "tags": ["scheduling", "meetings", "calendar"],
    "owner": "scheduling-team",
    "documentation_url": "https://docs.internal.example.com/scheduling/create-meeting",
    "auth_config": {
      "type": "oauth2",
      "token_url": "https://auth.internal.example.com/oauth/token",
      "scopes": ["scheduling:write"],
      "notes": "Uses client-credentials flow. Service account provisioned per team."
    },
    "rate_limit": { "requests_per_minute": 60 },
    "metadata": {
      "sla_ms": 500,
      "idempotent": false
    }
  },
  {
    "id": "ticketing.create-ticket",
    "name": "Create Support Ticket",
    "description": "Open a new support ticket in the internal ticketing system",
    "category": "ticketing",
    "version": "1.0.0",
    "tool_type": "REST_API",
    "endpoint": "https://api.internal.example.com/ticketing/tickets",
    "input_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "assignee": { "type": "string" },
        "labels": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "priority"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "ticket_id": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "status": { "type": "string" }
      }
    },
    "tags": ["ticketing", "support", "incidents"],
    "owner": "platform-team",
    "documentation_url": "https://docs.internal.example.com/ticketing/create-ticket",
    "auth_config": {
      "type": "api_key",
      "header": "X-Ticketing-Key",
      "notes": "Static API key per service. Rotate quarterly via Vault."
    },
    "rate_limit": { "requests_per_minute": 120 },
    "metadata": {
      "sla_ms": 300,
      "idempotent": false
    }
  },
  {
    "id": "notifications.send-email",
    "name": "Send Email Notification",
    "description": "Send a transactional email to one or more recipients",
    "category": "notifications",
    "version": "1.0.0",
    "tool_type": "REST_API",
    "endpoint": "https://api.internal.example.com/notifications/email",
    "input_schema": {
      "type": "object",
      "properties": {
        "to": { "type": "array", "items": { "type": "string", "format": "email" }, "minItems": 1 },
        "subject": { "type": "string", "minLength": 1 },
        "body_html": { "type": "string" },
        "body_text": { "type": "string" },
        "reply_to": { "type": "string", "format": "email" }
      },
      "required": ["to", "subject"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "message_id": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "tags": ["notifications", "email", "messaging"],
    "owner": "comms-team",
    "documentation_url": "https://docs.internal.example.com/notifications/email",
    "auth_config": {
      "type": "oauth2",
      "token_url": "https://auth.internal.example.com/oauth/token",
      "scopes": ["notifications:send"],
      "notes": "Client-credentials flow. Requires approved sender domain."
    },
    "rate_limit": { "requests_per_minute": 200 },
    "metadata": {
      "sla_ms": 1000,
      "idempotent": true
    }
  },
  {
    "id": "routing.find-route",
    "name": "Find Optimal Route",
    "description": "Calculate the optimal route between two geographic coordinates",
    "category": "routing",
    "version": "1.0.0",
    "tool_type": "REST_API",
    "endpoint": "https://api.internal.example.com/routing/directions",
    "input_schema": {
      "type": "object",
      "properties": {
        "origin": {
          "type": "object",
          "properties": {
            "lat": { "type": "number", "minimum": -90, "maximum": 90 },
            "lng": { "type": "number", "minimum": -180, "maximum": 180 }
          },
          "required": ["lat", "lng"]
        },
        "destination": {
          "type": "object",
          "properties": {
            "lat": { "type": "number", "minimum": -90, "maximum": 90 },
            "lng": { "type": "number", "minimum": -180, "maximum": 180 }
          },
          "required": ["lat", "lng"]
        },
        "mode": { "type": "string", "enum": ["driving", "walking", "transit"], "default": "driving" }
      },
      "required": ["origin", "destination"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "distance_km": { "type": "number" },
        "duration_minutes": { "type": "number" },
        "polyline": { "type": "string" }
      }
    },
    "tags": ["routing", "maps", "directions"],
    "owner": "logistics-team",
    "documentation_url": "https://docs.internal.example.com/routing/directions",
    "auth_config": {
      "type": "api_key",
      "header": "Authorization",
      "prefix": "Bearer",
      "notes": "Machine-to-machine JWT issued by internal auth service. No user context needed."
    },
    "rate_limit": { "requests_per_minute": 300 },
    "metadata": {
      "sla_ms": 200,
      "idempotent": true
    }
  },
  {
    "id": "users.lookup",
    "name": "User Lookup",
    "description": "Look up an internal user by email or employee ID and return profile details",
    "category": "identity",
    "version": "1.0.0",
    "tool_type": "REST_API",
    "endpoint": "https://api.internal.example.com/users/lookup",
    "input_schema": {
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "employee_id": { "type": "string" }
      },
      "oneOf": [
        { "required": ["email"] },
        { "required": ["employee_id"] }
      ]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "employee_id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "department": { "type": "string" },
        "manager": { "type": "string" }
      }
    },
    "tags": ["identity", "users", "directory"],
    "owner": "identity-team",
    "documentation_url": "https://docs.internal.example.com/users/lookup",
    "auth_config": {
      "type": "mtls",
      "notes": "Mutual TLS with client certificate issued by internal CA. No additional tokens needed."
    },
    "rate_limit": { "requests_per_minute": 500 },
    "metadata": {
      "sla_ms": 100,
      "idempotent": true
    }
  }
]
