# Railway often sets postgres:// or postgresql://…; the app normalizes to postgresql+asyncpg:// for asyncpg.
# In Railway: add the Postgres plugin and reference its DATABASE_URL on your web service (Variables).
DATABASE_URL=postgresql+asyncpg://tooloftools:tooloftools@localhost:5432/tooloftools
# Optional override for built SPA (defaults to ./frontend/dist).
# FRONTEND_DIST=/app/frontend/dist
# Temporary fallback if migrations are not yet wired in deploy flow.
# AUTO_CREATE_TABLES_ON_STARTUP=true
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Registration / login policy
# REGISTER_ALLOWED=true
# PASSWORD_LOGIN_ENABLED=true

# Break-glass admin (optional)
# BOOTSTRAP_ADMIN_ENABLED=true
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=use-a-long-random-secret

# OIDC (optional; set OIDC_ENABLED=true)
# OIDC_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/oidc/callback
# PUBLIC_APP_URL=http://localhost:5173
